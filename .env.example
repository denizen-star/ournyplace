# PlanetScale connection string
DATABASE_URL=https://username:password@host/dbname

# Telemetry / local app identifier
APP_NAME=nyhome

# --- Email (digest + “listing added” + “scoring complete” + “rejected”) ---
# NYHOME_EMAIL_TO receives:
# - Pipeline digest (manual POST /api/pipeline-digest-email)
# - New listing (POST /api/apartments create) — same HTML layout as below — skipped if the new listing’s status is rejected (bummer email is sent instead)
# - Scoring complete: automatically when both partners give 0–5 on every criterion (once per “completion cycle”; clearing any score resets that); or manually from Apartment details → “Email scoring summary” (POST /api/listing-scores-email)
# - “Bummer” rejection email when status changes into rejected (PUT/POST /api/apartments); same recipients as above
# Example SMTP (use your real host, user, and app password in .env.local / Netlify only).
NYHOME_SMTP_SERVER=smtp.example.com
NYHOME_SMTP_PORT=587
NYHOME_SMTP_USER=nyhome-smtp-login@example.invalid
NYHOME_SMTP_PASS=your-app-specific-password
NYHOME_EMAIL_FROM=nyhome-mail-from@example.invalid
NYHOME_EMAIL_TO=nyhome-recipient-a@example.invalid,nyhome-recipient-b@example.invalid

# Optional: default base for /details/?id= links in the message (browser can also send publicBaseUrl).
# NYHOME_PUBLIC_URL=https://your-site.netlify.app
