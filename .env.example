# PlanetScale connection string
DATABASE_URL=https://username:password@host/dbname

# Telemetry / local app identifier
APP_NAME=nyhome

# --- Email (digest + “listing added” + “scoring complete”) ---
# NYHOME_EMAIL_TO receives:
# - Pipeline digest (manual POST /api/pipeline-digest-email)
# - New listing (POST /api/apartments create) — same HTML layout as below
# - Scoring complete: automatically when both partners give 0–5 on every criterion (once per “completion cycle”; clearing any score resets that); or manually from Apartment details → “Email scoring summary” (POST /api/listing-scores-email)
# Zoho (same idea as Hunter): TLS on 587. Use an app password if 2FA is on.
NYHOME_SMTP_SERVER=smtp.zoho.com
NYHOME_SMTP_PORT=587
NYHOME_SMTP_USER=info@kervinapps.com
NYHOME_SMTP_PASS=your-app-specific-password
NYHOME_EMAIL_FROM=info@kervinapps.com
NYHOME_EMAIL_TO=peterpapapetrou1@gmail.com,leacock.kervin@gmail.com

# Optional: default base for /details/?id= links in the message (browser can also send publicBaseUrl).
# NYHOME_PUBLIC_URL=https://your-site.netlify.app
